# Salin fail ni ke ".env" dan isi nilai sebenar.
# JANGAN sesekali commit/upload fail ".env" sebenar ke git/public repo.

APP_ENV=production
APP_URL=https://cukrustorage.example.com
APP_TIMEZONE=Asia/Kuala_Lumpur

DB_HOST=localhost
DB_PORT=3306
DB_NAME=u123456789_cukrustorage
DB_USER=u123456789_dbuser
DB_PASS=ubah_password_ni
DB_CHARSET=utf8mb4

# Digunakan untuk menjana token QR & CSRF - tukar kepada rentetan rawak panjang sendiri
APP_SECRET=tukar_kepada_random_string_panjang_minimum_32_aksara

# Digunakan untuk hantar emel reset PIN (boleh guna SMTP Hostinger atau servis lain)
MAIL_FROM=noreply@cukrustorage.example.com
MAIL_FROM_NAME="CukruStorage"
